@page "/unsorted"
@inject ArmorDataService Data

<PageTitle>Unsorted Armor — HD2 Armorer</PageTitle>

@if (!Data.IsLoaded)
{
    <div class="loading-state">
        <div class="loading-text">Loading Armory...</div>
    </div>
}
else
{
    var unsorted = Data.ArmorSets.Where(a => a.SortOrder >= 9000).ToList();

    @if (unsorted.Count == 0)
    {
        <div class="no-results">All armor sort orders are known.</div>
    }
    else
    {
        <p class="unsorted-hint">
            These armor sets don't have a recorded in-game sort position and appear at the bottom of their weight class.
            If you own any, open the in-game armory and note the armor immediately <strong>before</strong> and
            immediately <strong>after</strong> it in the list, then
            <a href="https://github.com/jhr007/helldivers2armorer/issues" target="_blank" rel="noopener">open an issue</a>
            with those neighbors so the sort order can be placed correctly.
        </p>
    }

    @foreach (var weightClass in new[] { "Light", "Medium", "Heavy" })
    {
        var group = unsorted.Where(a => a.WeightClass == weightClass).OrderBy(a => a.DisplayName).ToList();
        if (group.Count > 0)
        {
            <section class="weight-section">
                <h2 class="weight-heading @weightClass.ToLower()">@weightClass</h2>
                <div class="armor-grid">
                    @foreach (var armor in group)
                    {
                        <ArmorTile Armor="armor" />
                    }
                </div>
            </section>
        }
    }
}

@code {
    protected override async Task OnInitializedAsync() => await Data.LoadAsync();
}

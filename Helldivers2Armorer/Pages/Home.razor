@page "/"
@inject ArmorDataService Data
@inject IJSRuntime JS

<PageTitle>Helldivers 2 Armorer</PageTitle>

@if (!Data.IsLoaded)
{
    <div class="loading-state">
        <div class="loading-text">Loading Armory...</div>
    </div>
}
else
{
    @if (passiveDropdownOpen)
    {
        <div class="dropdown-backdrop" @onclick="() => passiveDropdownOpen = false"></div>
    }

    <div class="filter-bar">
        <div class="filter-controls">
            <div class="search-wrap">
                <input class="search-input" type="text" placeholder="Search armor, passive, tag, or short description..."
                       @bind="searchText" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(searchText))
                {
                    <button class="search-clear" @onclick="ClearSearch" aria-label="Clear search">×</button>
                }
            </div>

            <div class="passive-dropdown @(passiveDropdownOpen ? "open" : "")">
                <button class="passive-dropdown-trigger" @onclick="TogglePassiveDropdown">
                    Passive ability...
                    <span class="dropdown-arrow">▾</span>
                </button>
                @if (passiveDropdownOpen)
                {
                    <div class="passive-dropdown-menu">
                        @foreach (var p in Data.Passives.OrderBy(p => p.DisplayName))
                        {
                            if (!activePassives.Contains(p.DisplayName))
                            {
                                <button class="passive-option" @onclick="() => SelectPassive(p.DisplayName)">
                                    <img src="images/armorpassives/@p.ImageURL" class="passive-opt-icon" alt="" />
                                    <span>@p.DisplayName</span>
                                </button>
                            }
                        }
                    </div>
                }
            </div>

            <select class="filter-select" @bind="selectedFeature" @bind:after="AddFeature">
                <option value="">Feature tag...</option>
                @foreach (var tag in Data.AllFeatureTags)
                {
                    if (!activeFeatureTags.Contains(tag))
                    {
                        <option value="@tag">@FormatTag(tag)</option>
                    }
                }
            </select>

            <div class="filter-spacer"></div>

            <button class="filter-toggle @(showOwnedBadges ? "active" : "")"
                    @onclick="ToggleOwnedBadges"
                    title="@(showOwnedBadges ? "Disable owned icons on tiles" : "Enable owned icons on tiles")">
                @(showOwnedBadges ? "Disable owned icons" : "Enable owned icons")
            </button>

            @if (ownedArmors.Count > 0)
            {
                <button class="filter-toggle @(showOwnedOnly ? "active" : "")"
                        @onclick="ToggleOwnedOnly"
                        title="@(showOwnedOnly ? "Show all armors" : "Show only armors you have marked as owned")">
                    @(showOwnedOnly ? "Show all" : "Show owned")
                </button>
            }
        </div>

        @if (activePassives.Count > 0 || activeFeatureTags.Count > 0)
        {
            <div class="active-filters">
                @foreach (var passive in activePassives)
                {
                    <span class="filter-pill passive-pill">
                        @if (Data.PassiveMap.TryGetValue(passive, out var pd))
                        {
                            <img src="images/armorpassives/@pd.ImageURL" class="pill-icon" alt="" />
                        }
                        @passive
                        <button class="pill-remove" @onclick="() => RemovePassive(passive)" aria-label="Remove">×</button>
                    </span>
                }
                @foreach (var tag in activeFeatureTags)
                {
                    <span class="filter-pill feature-pill">
                        @FormatTag(tag)
                        <button class="pill-remove" @onclick="() => RemoveFeatureTag(tag)" aria-label="Remove">×</button>
                    </span>
                }
                <button class="clear-all" @onclick="ClearAll">Clear all</button>
            </div>
        }

        <SelectedArmorList @ref="armorList" AllArmors="Data.ArmorSets" OnSelectionChanged="StateHasChanged" />
    </div>

    var filtered = Data.Filter(activePassives, activeFeatureTags);
    if (!string.IsNullOrWhiteSpace(searchText))
    {
        var s = searchText.Trim();
        filtered = filtered.Where(a =>
            a.DisplayName.Contains(s, StringComparison.OrdinalIgnoreCase) ||
            a.Passive.Contains(s, StringComparison.OrdinalIgnoreCase) ||
            (a.PassiveInfo?.ShortDescription.Contains(s, StringComparison.OrdinalIgnoreCase) == true) ||
            (a.PassiveInfo?.AbilityTags.Any(t =>
                t.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                FormatTag(t).Contains(s, StringComparison.OrdinalIgnoreCase)) == true)
        ).ToList();
    }
    if (showOwnedOnly)
    {
        filtered = filtered.Where(a => ownedArmors.Contains(a.InternalName)).ToList();
    }

    @foreach (var weightClass in new[] { "Light", "Medium", "Heavy" })
    {
        var group = filtered.Where(a => a.WeightClass == weightClass).OrderBy(a => a.SortOrder).ToList();
        if (group.Count > 0)
        {
            var collapsed = collapsedWeights.Contains(weightClass);
            <section class="weight-section">
                <div class="weight-heading-row" @onclick="() => ToggleCollapse(weightClass)"
                     title="@(collapsed ? "Expand" : "Collapse") @weightClass section">
                    <h2 class="weight-heading @weightClass.ToLower()">
                        <i class="bi @(collapsed ? "bi-chevron-right" : "bi-chevron-down") weight-collapse-icon"></i>
                        @weightClass
                    </h2>
                    <span class="weight-count">@group.Count</span>
                </div>
                @if (!collapsed)
                {
                    <div class="armor-grid">
                        @foreach (var armor in group)
                        {
                            <ArmorTile Armor="armor"
                                       Selected="(armorList?.IsSelected(armor.InternalName) ?? false)"
                                       Owned="ownedArmors.Contains(armor.InternalName)"
                                       ShowOwnedBadge="showOwnedBadges"
                                       OnClick="() => armorList!.ToggleSelection(armor.InternalName)"
                                       OnPassiveClick="SelectPassive"
                                       OnTagClick="tag => activeFeatureTags.Add(tag)"
                                       OnOwnedToggle="ToggleOwned" />
                        }
                    </div>
                }
            </section>
        }
    }

    if (filtered.Count == 0)
    {
        <div class="no-results">No armor matches the selected filters.</div>
    }
}

@code {
    private HashSet<string> activePassives = [];
    private HashSet<string> activeFeatureTags = [];
    private HashSet<string> ownedArmors = [];
    private HashSet<string> collapsedWeights = [];
    private SelectedArmorList? armorList;
    private string selectedFeature = "";
    private string searchText = "";
    private bool passiveDropdownOpen = false;
    private bool showOwnedBadges = true;
    private bool showOwnedOnly = false;

    private const string OwnedStorageKey       = "hd2armorer.owned";
    private const string ShowBadgesStorageKey  = "hd2armorer.showOwnedBadges";
    private const string ShowOwnedStorageKey   = "hd2armorer.showOwnedOnly";

    protected override async Task OnInitializedAsync()
    {
        await Data.LoadAsync();

        var storedOwned = await JS.InvokeAsync<string?>("localStorage.getItem", OwnedStorageKey);
        if (!string.IsNullOrEmpty(storedOwned))
        {
            var list = System.Text.Json.JsonSerializer.Deserialize<List<string>>(storedOwned);
            if (list is not null) ownedArmors = [.. list];
        }

        var storedBadges = await JS.InvokeAsync<string?>("localStorage.getItem", ShowBadgesStorageKey);
        if (storedBadges is not null)
            showOwnedBadges = storedBadges == "true";

        var storedOnly = await JS.InvokeAsync<string?>("localStorage.getItem", ShowOwnedStorageKey);
        if (storedOnly is not null)
            showOwnedOnly = storedOnly == "true";
    }

    private async Task ToggleOwnedBadges()
    {
        showOwnedBadges = !showOwnedBadges;
        await JS.InvokeVoidAsync("localStorage.setItem", ShowBadgesStorageKey, showOwnedBadges.ToString().ToLower());
    }

    private async Task ToggleOwnedOnly()
    {
        showOwnedOnly = !showOwnedOnly;
        await JS.InvokeVoidAsync("localStorage.setItem", ShowOwnedStorageKey, showOwnedOnly.ToString().ToLower());
    }

    private async Task ToggleOwned(string internalName)
    {
        if (!ownedArmors.Remove(internalName)) ownedArmors.Add(internalName);
        await JS.InvokeVoidAsync("localStorage.setItem", OwnedStorageKey,
            System.Text.Json.JsonSerializer.Serialize(ownedArmors.ToList()));
    }

    private void ToggleCollapse(string weightClass)
    {
        if (!collapsedWeights.Remove(weightClass)) collapsedWeights.Add(weightClass);
    }

    private void TogglePassiveDropdown() => passiveDropdownOpen = !passiveDropdownOpen;

    private void SelectPassive(string name)
    {
        activePassives.Add(name);
        passiveDropdownOpen = false;
    }

    private void AddFeature()
    {
        if (!string.IsNullOrEmpty(selectedFeature)) activeFeatureTags.Add(selectedFeature);
        selectedFeature = "";
    }

    private void ClearSearch() => searchText = "";
    private void RemovePassive(string p) => activePassives.Remove(p);
    private void RemoveFeatureTag(string t) => activeFeatureTags.Remove(t);
    private void ClearAll() { activePassives.Clear(); activeFeatureTags.Clear(); searchText = ""; }

    private static string FormatTag(string tag) =>
        string.Join(" ", tag.Split('-').Select(w => char.ToUpper(w[0]) + w[1..]));
}
